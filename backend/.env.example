# MongoDB Atlas connection string
MONGODB_URI=

# JWT signing secret (Authorization: Bearer <token> issued on login)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# AES-256-GCM key used to encrypt the /wa-login self-registration PIN at rest (User.waLoginPin).
# Must be a 64-character hex string. Generate with: openssl rand -hex 32
PIN_ENCRYPTION_KEY=

# Comma-separated list of allowed frontend origins for CORS, e.g.:
# https://your-frontend.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Base URL of the deployed frontend — used to build the one-tap "already logged in" link
# sent back over WhatsApp by the /wa-login self-registration flow.
FRONTEND_URL=https://packwithme.instify.in

# Port Express listens on. Render sets this automatically in production.
PORT=4000

# MSG91 "Login with OTP" widget — SECRET account Auth Key (server only, never commit a real
# value). Backend confirms the widget access-token the browser posts and reads the verified
# mobile from it (see src/services/msg91Service.ts). This is the PRIMARY auth path now
# (passwordless mobile + OTP login). Reuses the SAME MSG91 widget/account as the WhatsLocal
# project — the widget's public half is set on the frontend (VITE_MSG91_WIDGET_ID /
# VITE_MSG91_TOKEN_AUTH). Required for login to work in production.
MSG91_AUTH_KEY=

# WhatsApp Cloud API (Meta Graph API) — used to send OTP codes for self-registration
# and forgot-password, via an approved Authentication-category template message.
# See README "WhatsApp OTP setup" for how to obtain these from developers.facebook.com.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v18.0
# Must match an approved WhatsApp Authentication template name/language.
WHATSAPP_OTP_TEMPLATE_NAME=instify_otp
WHATSAPP_OTP_TEMPLATE_LANGUAGE=en_US

# Admin new-registration WhatsApp alerts (see src/services/adminNotifyService.ts). Admins are
# just User documents with role: "admin" (scripts/make-admin.ts) — no separate setup needed
# there. An admin "opts in" simply by sending any WhatsApp message to this business number,
# which opens Meta's 24h customer-service window (src/routes/whatsapp.routes.ts). While that
# window is open, new-user registrations are pushed as free-form text. To keep the window from
# lapsing, src/jobs/waAdminReactivation.ts sends up to 3 reminder messages per window using the
# approved Utility template below, which must have a button (quick reply or call-to-action) —
# tapping it re-opens the window. Must match an approved template name/language.
WHATSAPP_ADMIN_REACTIVATION_TEMPLATE_NAME=admin_window_reactivation
WHATSAPP_ADMIN_REACTIVATION_TEMPLATE_LANGUAGE=en_US

# Cloudinary — used to host checklist item photos instead of storing them inline as
# base64 in Mongo. Get these from https://console.cloudinary.com/app/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Metabsp WhatsApp forwarding hub — shared secret used to verify the
# X-Metabsp-Signature-256 HMAC on incoming POST /api/whatsapp/webhook-metabsp requests.
# Obtain this from whoever registers this project's callback URL in Metabsp.
METABSP_WEBHOOK_SECRET=

# Analytics (see backend/src/models/AnalyticsEvent.ts)
# Salt used to HMAC-hash visitor IPs before storage — raw IPs are never stored. Generate
# with: openssl rand -base64 32
IP_HASH_SALT=
# How many days of raw analytics events to keep before Mongo's TTL index auto-deletes them.
ANALYTICS_TTL_DAYS=180
