# MongoDB Atlas connection string (see README "MongoDB Atlas setup")
MONGODB_URI=

# NextAuth / Auth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Local dev: http://localhost:3000 — in production, set to your deployed URL
NEXTAUTH_URL=http://localhost:3000

# Meta WhatsApp Cloud API (see README "Meta WhatsApp Cloud API setup")
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_APP_ID=
META_APP_SECRET=

# The actual WhatsApp Business phone number (digits only, with country code,
# e.g. 919876543210) that the login QR/deep-link points to. This is NOT the
# same as META_PHONE_NUMBER_ID above, which is Meta's internal ID for the number.
META_BUSINESS_NUMBER=
