# MongoDB Atlas connection string (see README "MongoDB Atlas setup")
MONGODB_URI=

# NextAuth / Auth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Local dev: http://localhost:3000 — in production, set to your deployed URL
NEXTAUTH_URL=http://localhost:3000

# Meta WhatsApp Cloud API — used only for admin broadcast messages, not login
# (see README "Meta WhatsApp Cloud API setup")
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=

# MSG91 OTP widget (see README "MSG91 OTP setup") — used for mobile OTP login
# Public widget credentials, safe to expose client-side:
NEXT_PUBLIC_MSG91_WIDGET_ID=
NEXT_PUBLIC_MSG91_TOKEN_AUTH=
# Secret account authkey, server-side only — used to verify the widget's access token:
MSG91_AUTH_KEY=

# OPTIONAL, DANGEROUS: enables /dev-login?secret=<this value>, which signs in as a
# fixed test account bypassing OTP verification entirely. Leave unset in normal
# operation — only set it temporarily while setting up the real MSG91 widget, then remove it.
# Generate with: openssl rand -hex 24
DEV_LOGIN_SECRET=

# Metabsp shared-WhatsApp-number webhook forwarding (app/api/whatsapp/webhook-metabsp)
# Must match the full secret shown for this destination in Metabsp's own
# "Webhook destinations" panel — used to verify the X-Metabsp-Signature-256 header.
METABSP_WEBHOOK_SECRET=
